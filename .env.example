# Copy this file to ".env" and fill in your values.
# These come from your Supabase project (Settings -> API).
# The anon/publishable key is safe to expose publicly (it already ships in the
# browser bundle). Row-level security controls what it can read.

PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-publishable-key"
