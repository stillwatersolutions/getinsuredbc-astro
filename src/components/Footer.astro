---
import { NAV, SITE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="bg-primary text-white/90 mt-24">
  <div class="mx-auto max-w-6xl px-5 py-14 grid gap-10 md:grid-cols-3">
    <div>
      <p class="font-display text-2xl font-black text-white">{SITE.title}</p>
      <p class="mt-3 text-sm text-white/70 max-w-xs">
        Helping one British Columbian at a time find the right coverage for their situation.
      </p>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-white/60">Quick Links</p>
      <ul class="mt-3 space-y-2 text-sm">
        {NAV.map((item) => (
          <li><a href={item.href} class="hover:underline">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-white/60">Contact</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href={`mailto:${SITE.email}`} class="hover:underline">{SITE.email}</a></li>
        <li>{SITE.address.street}, {SITE.address.city}, {SITE.address.region}</li>
      </ul>
      <p class="mt-4 text-xs text-white/50">Licensed insurance broker in British Columbia</p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-5 py-5 flex flex-col sm:flex-row justify-between gap-3 text-xs text-white/50">
      <span>&copy; {year} {SITE.title}. All rights reserved.</span>
      <span class="flex gap-4">
        <a href="/privacy" class="hover:underline">Privacy Policy</a>
        <a href="/terms" class="hover:underline">Terms of Service</a>
      </span>
    </div>
  </div>
</footer>
