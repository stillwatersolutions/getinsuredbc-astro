---
// Ported from the original Lovable Footer.tsx
const year = new Date().getFullYear();
---
<footer class="bg-accent text-accent-foreground">
  <div class="h-1 bg-gradient-to-r from-primary via-primary/80 to-primary"></div>

  <div class="container mx-auto px-4 max-w-7xl py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Logo + tagline + social -->
      <div class="space-y-6">
        <img src="/assets/getinsuredbc-logo-new.png" alt="getinsuredBC" class="h-16 w-auto mb-4 brightness-0 invert" />
        <p class="text-accent-foreground/70 text-sm">Helping one British Columbian at a time.</p>
        <div class="flex gap-4">
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="h-10 w-10 rounded-full bg-accent-foreground/10 hover:bg-primary flex items-center justify-center transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.5 9.9v-7H8v-2.9h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.300000000000001c-1.2 0-1.6.8-1.6 1.5v1.8H17l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-serif font-bold text-base mb-6 text-accent-foreground">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/#how-it-works" class="text-accent-foreground/70 hover:text-accent-foreground transition-colors text-[15px]">How It Works</a></li>
          <li><a href="/#faq" class="text-accent-foreground/70 hover:text-accent-foreground transition-colors text-[15px]">FAQ</a></li>
          <li><a href="/blog" class="text-accent-foreground/70 hover:text-accent-foreground transition-colors text-[15px] inline-flex items-center gap-2">Blog <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-serif font-bold text-base mb-6 text-accent-foreground">Contact</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3 text-accent-foreground/70">
            <svg class="mt-0.5 shrink-0 text-primary-foreground" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
            <a href="mailto:joel@getinsuredBC.com" class="hover:text-accent-foreground transition-colors text-[15px]">joel@getinsuredBC.com</a>
          </div>
          <div class="flex items-start gap-3 text-accent-foreground/70">
            <svg class="mt-0.5 shrink-0 text-primary-foreground" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+49123456789" class="hover:text-accent-foreground transition-colors text-[15px]">+49 123 456789</a>
          </div>
          <div class="flex items-start gap-3 text-accent-foreground/70">
            <svg class="mt-0.5 shrink-0 text-primary-foreground" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-[15px]">329 Howe St, Vancouver, BC</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-accent-foreground/20">
      <p class="text-center text-accent-foreground/60 text-sm">Licensed insurance broker in British Columbia</p>
    </div>

    <div class="mt-8 pt-8 border-t border-accent-foreground/20 flex flex-col md:flex-row justify-between items-center gap-4 text-accent-foreground/60 text-sm">
      <p>&copy; {year} getinsuredBC. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="hover:text-accent-foreground transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="hover:text-accent-foreground transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
