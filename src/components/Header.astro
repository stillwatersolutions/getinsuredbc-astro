---
// Ported from the original Lovable Header.tsx
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-[12px] border-b border-[#E5E7EB]">
  <div class="container mx-auto px-4 py-3 max-w-7xl">
    <nav class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/assets/getinsuredbc-logo-new.png" alt="getinsuredBC" class="h-12 w-auto" />
      </a>

      <!-- Desktop -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/#about" class="text-foreground/70 hover:text-foreground transition-colors font-medium">About</a>
        <a href="/#how-it-works" class="text-foreground/70 hover:text-foreground transition-colors font-medium">How It Works</a>
        <a href="/#faq" class="text-foreground/70 hover:text-foreground transition-colors font-medium">FAQ</a>
        <button type="button" data-open-quiz class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-semibold transition-all duration-300 bg-primary hover:bg-primary-dark text-primary-foreground rounded-full px-6 h-10">
          Get Started
        </button>
      </div>

      <!-- Mobile toggle -->
      <button type="button" id="mobile-menu-btn" class="md:hidden" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden mt-4 flex-col gap-4 pb-4 animate-fade-in hidden">
      <a href="/#about" class="text-foreground/70 hover:text-foreground transition-colors font-medium">About</a>
      <a href="/#how-it-works" class="text-foreground/70 hover:text-foreground transition-colors font-medium">How It Works</a>
      <a href="/#faq" class="text-foreground/70 hover:text-foreground transition-colors font-medium">FAQ</a>
      <button type="button" data-open-quiz class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-semibold transition-all duration-300 w-full bg-primary hover:bg-primary-dark text-primary-foreground rounded-full px-6 h-10">
        Get Started
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', function () {
        menu.classList.toggle('hidden');
        menu.classList.toggle('flex');
      });
    }
  })();
</script>
