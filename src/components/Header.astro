---
import { NAV, SITE } from '../consts';
const path = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-background/90 backdrop-blur border-b border-muted">
  <nav class="mx-auto max-w-6xl flex items-center justify-between px-5 py-4">
    <a href="/" class="font-display text-xl font-black text-primary tracking-tight">
      {SITE.title}
    </a>

    <ul class="hidden md:flex items-center gap-7 text-sm font-medium">
      {NAV.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'transition-colors hover:text-primary',
              path === item.href ? 'text-primary' : 'text-muted-foreground',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      type="button"
      data-open-quiz
      class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-transform hover:scale-105"
    >
      Get Started
    </button>
  </nav>
</header>
