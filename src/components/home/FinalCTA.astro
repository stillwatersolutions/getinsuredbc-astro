---
// Ported from FinalCTA.tsx (Lottie via dotlottie web component)
---
<section class="py-20 px-4 bg-accent-light/30">
  <div class="container mx-auto max-w-7xl">
    <div class="grid lg:grid-cols-2 gap-8 md:gap-12 items-center">
      <div class="animate-fade-in space-y-6 text-center lg:text-left">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground">Protect those who matter</h2>
        <p class="text-base md:text-lg text-muted-foreground leading-relaxed max-w-xl mx-auto lg:mx-0">
          We'd do anything for our loved ones—and now, for less than the cost of weekly takeout, you can get life insurance that protects your family financially for life.
        </p>
        <button type="button" data-open-quiz class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-semibold transition-all duration-300 bg-primary hover:bg-primary-dark text-primary-foreground rounded-md px-8 h-12">
          Get Help
          <svg class="h-4 w-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </div>

      <div class="relative animate-fade-in min-h-[300px] lg:min-h-[400px] flex items-center justify-center">
        <dotlottie-wc src="/assets/family.lottie" autoplay loop class="w-full h-full" style="transform:scale(1.5)"></dotlottie-wc>
      </div>
    </div>
  </div>
</section>
