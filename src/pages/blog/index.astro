---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getSupabasePosts } from '../../lib/supabase';

// Markdown posts (Claude-written, future flagship pieces)
const md = (await getCollection('blog', ({ data }) => !data.draft)).map((p) => ({
  slug: p.id,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  tags: p.data.tags,
}));

// Supabase posts (the existing 240, built static)
const sb = (await getSupabasePosts()).map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.meta_description || p.excerpt || '',
  pubDate: new Date(p.published_at),
  tags: p.category ? [p.category.name] : [],
}));

const posts = [...md, ...sb].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Insurance Knowledge Hub"
  description="Expert insights and answers to your insurance questions in British Columbia — life, critical illness, disability, and group benefits."
>
  <section class="mx-auto max-w-4xl px-5 py-16">
    <h1 class="text-4xl md:text-5xl text-primary">Insurance Knowledge Hub</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      Expert insights and answers to your insurance questions.
    </p>

    <div class="mt-12 space-y-8">
      {posts.length === 0 && (
        <p class="text-muted-foreground">No posts yet — the first articles are on the way.</p>
      )}
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="block rounded-2xl border border-muted bg-secondary/40 p-6 transition-colors hover:border-primary">
          <div class="flex flex-wrap gap-2 mb-3">
            {post.tags.map((t) => (
              <span class="rounded-full bg-accent-blue/40 px-3 py-1 text-xs font-medium text-primary">{t}</span>
            ))}
          </div>
          <h2 class="text-2xl text-primary">{post.title}</h2>
          <p class="mt-2 text-muted-foreground line-clamp-2">{post.description}</p>
          <p class="mt-3 text-sm text-muted-foreground">{fmt(post.pubDate)}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
