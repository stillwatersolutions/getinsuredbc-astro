---
import { getCollection, render } from 'astro:content';
import { getSupabasePosts } from '../../lib/supabase';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const md = await getCollection('blog', ({ data }) => !data.draft);
  const mdPaths = md.map((entry) => ({
    params: { slug: entry.id },
    props: { source: 'md' as const, entry },
  }));

  const sb = await getSupabasePosts();
  const sbPaths = sb.map((post) => ({
    params: { slug: post.slug },
    props: { source: 'sb' as const, post },
  }));

  return [...mdPaths, ...sbPaths];
}

const props = Astro.props as any;

let title: string,
  description: string,
  pubDate: Date,
  updatedDate: Date | undefined,
  author = 'GetInsuredBC',
  tags: string[] = [],
  Content: any = null,
  contentHtml: string | null = null,
  cta: { text: string; url: string } | null = null;

if (props.source === 'md') {
  const entry = props.entry;
  ({ Content } = await render(entry));
  title = entry.data.title;
  description = entry.data.description;
  pubDate = entry.data.pubDate;
  updatedDate = entry.data.updatedDate;
  author = entry.data.author;
  tags = entry.data.tags;
} else {
  const post = props.post;
  title = post.title;
  description = post.meta_description || post.excerpt || '';
  pubDate = new Date(post.published_at);
  tags = post.category ? [post.category.name] : [];
  contentHtml = post.content;
  if (post.internal_cta_url) {
    cta = { text: post.internal_cta_text || 'Learn more', url: post.internal_cta_url };
  }
}
---
<BlogPost
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  tags={tags}
>
  {Content ? <Content /> : <Fragment set:html={contentHtml} />}

  {cta && (
    <p class="mt-10">
      <a href={cta.url} class="inline-block rounded-full bg-primary px-6 py-3 font-semibold text-white no-underline">
        {cta.text}
      </a>
    </p>
  )}
</BlogPost>
