---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  { n: '1', title: 'Take the assessment', body: 'Answer a few quick questions about your situation — no jargon, no pressure.' },
  { n: '2', title: "We'll find your match", body: 'We compare options across providers to find coverage that actually fits.' },
  { n: '3', title: 'Get the perfect policy', body: 'Lock in protection for your family, often for less than weekly takeout.' },
];

const values = [
  { title: 'Affordable coverage', color: 'bg-peach', body: 'Protection that fits real BC budgets.' },
  { title: 'Simplicity', color: 'bg-coral', body: 'Plain language, no confusing fine print.' },
  { title: 'Flexibility', color: 'bg-skyblue', body: 'Options that adapt to your life stage.' },
  { title: 'Trust', color: 'bg-sage/50', body: 'A licensed BC broker on your side.' },
];
---
<BaseLayout>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-5 pt-20 pb-16 text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-terracotta">Life insurance made simple</p>
    <h1 class="mt-4 text-4xl md:text-6xl text-primary max-w-3xl mx-auto">
      Helping BC folks like you find the best coverage for your situation
    </h1>
    <p class="mt-6 text-lg text-muted-foreground max-w-xl mx-auto">
      Take our quick assessment and discover the right protection for your family — in minutes.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <button type="button" data-open-quiz class="rounded-full bg-primary px-7 py-3.5 font-semibold text-white transition-transform hover:scale-105">
        Get My Coverage Recommendation
      </button>
    </div>
  </section>

  <!-- Values -->
  <section class="mx-auto max-w-6xl px-5 py-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {values.map((v) => (
      <div class={`rounded-2xl ${v.color} p-6`}>
        <h3 class="text-xl text-primary">{v.title}</h3>
        <p class="mt-2 text-sm text-primary/80">{v.body}</p>
      </div>
    ))}
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="text-3xl md:text-4xl text-primary text-center">So, how does it work?</h2>
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {steps.map((s) => (
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-xl font-black text-white">
            {s.n}
          </div>
          <h3 class="mt-5 text-xl text-primary">{s.title}</h3>
          <p class="mt-2 text-sm text-muted-foreground">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Assessment CTA: opens the interactive quiz island -->
  <section id="assessment" class="mx-auto max-w-3xl px-5 py-16 text-center scroll-mt-24">
    <div class="rounded-3xl bg-secondary border border-muted p-10">
      <h2 class="text-3xl text-primary">Ready to find your coverage?</h2>
      <p class="mt-3 text-muted-foreground">
        Take the 2-minute assessment and get a personalized recommendation — plus a PDF summary
        of your options and any coverage gaps.
      </p>
      <button type="button" data-open-quiz class="mt-6 inline-block rounded-full bg-primary px-7 py-3.5 font-semibold text-white transition-transform hover:scale-105">
        Start the assessment
      </button>
    </div>
  </section>

  <!-- FAQ teaser -->
  <section class="mx-auto max-w-3xl px-5 py-12 text-center">
    <h2 class="text-3xl text-primary">Have questions? We've got answers.</h2>
    <p class="mt-3 text-muted-foreground">Read the most common questions about life insurance in BC.</p>
    <a href="/faq" class="mt-5 inline-block font-semibold text-primary underline underline-offset-4">Visit the FAQ &rarr;</a>
  </section>
</BaseLayout>
