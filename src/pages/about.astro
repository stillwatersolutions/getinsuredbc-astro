---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="GetInsuredBC is a licensed life insurance broker helping British Columbians find the right coverage.">
  <section class="mx-auto max-w-3xl px-5 py-16">
    <h1 class="text-4xl md:text-5xl text-primary">Helping one British Columbian at a time</h1>
    <div class="prose-content mt-8">
      <p>
        GetInsuredBC is a licensed insurance broker based in Vancouver, British Columbia. We help
        BC families cut through the jargon and find life, critical illness, disability, and funeral
        coverage that actually fits their situation and budget.
      </p>
      <p>
        We believe protecting the people you love shouldn't be confusing or expensive. That's why
        we built a simple assessment that matches you with the right coverage in minutes — and a
        real human broker to answer your questions along the way.
      </p>
    </div>
  </section>
</BaseLayout>
