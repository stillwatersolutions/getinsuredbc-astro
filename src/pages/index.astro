---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Benefits from '../components/home/Benefits.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import ReviewsRail from '../components/home/ReviewsRail.astro';
import WhyLifeInsurance from '../components/home/WhyLifeInsurance.astro';
import FaqHome from '../components/home/FaqHome.astro';
import FinalCTA from '../components/home/FinalCTA.astro';
---
<BaseLayout>
  <Hero />
  <Benefits />
  <HowItWorks />
  <ReviewsRail />
  <WhyLifeInsurance />
  <FaqHome />
  <FinalCTA />

  <!-- Scroll-trigger zone: opens the quiz as the visitor scrolls into it (ported from ScrollTriggerZone) -->
  <div slot="after-footer">
    <div id="scroll-trigger" class="relative h-[150vh] bg-accent flex flex-col items-center justify-start pt-24">
      <div class="text-center space-y-4 animate-pulse">
        <p class="text-accent-foreground/70 text-lg font-medium">Keep scrolling to start the quiz</p>
        <svg class="h-6 w-6 text-accent-foreground mx-auto animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
      </div>
    </div>
  </div>

  <!-- dotLottie web component for hero + final CTA animations -->
  <script type="module" src="https://unpkg.com/@lottiefiles/dotlottie-wc/dist/dotlottie-wc.js" is:inline></script>

  <script is:inline>
    // Scroll-trigger: open quiz when ~85% into the zone
    (function () {
      var zone = document.getElementById('scroll-trigger');
      if (!zone) return;
      var fired = false;
      function onScroll() {
        var rect = zone.getBoundingClientRect();
        var progress = Math.max(0, Math.min(1, (window.innerHeight - rect.top) / rect.height));
        if (progress > 0.85 && !fired) { fired = true; window.dispatchEvent(new CustomEvent('open-quiz')); }
        if (progress < 0.2) fired = false;
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();

    // Magnetic hover effect (ported from the framer-motion MagneticButton)
    (function () {
      document.querySelectorAll('[data-magnetic]').forEach(function (el) {
        el.addEventListener('mousemove', function (e) {
          var r = el.getBoundingClientRect();
          var dx = (e.clientX - (r.left + r.width / 2)) * 0.15;
          var dy = (e.clientY - (r.top + r.height / 2)) * 0.15;
          el.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
        });
        el.addEventListener('mouseleave', function () { el.style.transform = 'translate(0,0)'; });
      });
    })();
  </script>
</BaseLayout>
